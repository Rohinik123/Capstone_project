MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string
PORT=8001

# Recommended on Windows if querySrv ECONNREFUSED (SRV DNS). Loaded after dotenv (see index.js).
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Alternative: use a standard (non-SRV) URI from Atlas Connect → Drivers (mongodb://host1:27017,host2:27017,...)
# and set it as MONGO_URI instead of mongodb+srv://...
